<%- include("partials/header",{showNavigation:true}) %>

    <h1 class="page-title">Edit Movie</h1>
    <hr />



    <form class="edit-form" method="post">
        <label for="title">Title:</label>
        <input type="text" name="name" placeholder="Movie Title" value="<%=movie.name%>" required>
        <% if (errors?.name) { %>
            <span class="error-message">
                <%= errors.name.msg %>
            </span>
        <% } %>

        <label for="year">Year:</label>
        <input type="number" name="year" placeholder="Year" value="<%=movie.year%>" required>
        <% if (errors?.year) { %>
            <span class="error-message">
                <%= errors.year.msg %>
            </span>
        <% } %>

        <label for="rating">Rating:</label>
        <input type="number" name="rating" placeholder="Rating" value="<%=movie.rating%>" required>
        <% if (errors?.rating) { %>
            <span class="error-message">
                <%= errors.rating.msg %>
            </span>
        <% } %>

        <label for="genres">Genres:</label>
        <input type="text" name="genres" placeholder="Genres" value="<%=movie.genres%>" required>
        <% if (errors?.genres) { %>
            <span class="error-message">
                <%= errors.genres.msg %>
            </span>
        <% } %>

        <label for="director">Director:</label>
        <input type="text" name="director" placeholder="Director" value="<%=movie.director%>" required>
        <% if (errors?.director) { %>
            <span class="error-message">
                <%= errors.director.msg %>
            </span>
        <% } %>

        <label for="description">Description:</label>
        <textarea type="text" name="description" placeholder="Description" rows="4"
            required><%=movie.description%></textarea>
        <% if (errors?.description) { %>
            <span class="error-message">
                <%= errors.description.msg %>
            </span>
        <% } %>

        <div class="button-container">
            <button class="button">Save</button>
        </div>
    </form>

    <%- include("partials/footer") %>